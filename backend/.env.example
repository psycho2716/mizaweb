PORT=4000
FRONTEND_URL=http://localhost:3000

# Supabase: use your hosted project URL (https://xxxx.supabase.co) OR local API from `npx supabase status -o env` (API_URL).
# Local ports are 58100+ (see supabase/config.toml) so they stay outside common Windows reserved ranges (e.g. 57976–58075).
SUPABASE_URL=http://127.0.0.1:58100
# Required for login/register: Supabase Auth (anon) + service role.
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

SUPABASE_VERIFICATION_BUCKET=verification-docs
SUPABASE_PRODUCT_MEDIA_BUCKET=product-media
# Used only when Supabase Auth env is incomplete (local tests / fallback).
JWT_SECRET=replace-with-strong-secret

GOOGLE_MAPS_API_KEY=your_google_maps_server_key
GOOGLE_DIRECTIONS_API_KEY=your_google_directions_server_key

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

FAL_API_KEY=your_fal_api_key
# Optional: block 3D (Trellis) when fal-ai/imageutils/nsfw score >= threshold (0–1). Higher = stricter.
# FAL_NSFW_THRESHOLD=0.72
# Dev only — skips NSFW gate (Trellis may still fail on sensitive images).
# FAL_SKIP_NSFW_GATE=1

ADMIN_ID=
ADMIN_EMAIL=
ADMIN_PASSWORD=
